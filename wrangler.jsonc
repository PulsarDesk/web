{
	// Cloudflare Workers static-assets deploy: the site is fully prerendered
	// by adapter-static into build/ — no server code, assets only.
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "pulsar-web",
	"compatibility_date": "2026-07-13",
	"assets": {
		"directory": "./build"
	}
}
